# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=your_telegram_token
LOG_LEVEL=INFO

# =========================
# Main Paths
# =========================
VECTOR_DB_DIR=vectordb
COLLECTION_NAME=diabetes_refs
VERIFIED_FAQ_PATH=data/verified_faq.json
CHAT_LOG_PATH=logs/chat_history.jsonl

# =========================
# Model Providers
# =========================
EMBEDDING_PROVIDER=ollama
LLM_PROVIDER=ollama

# =========================
# Ollama
# =========================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.1:8b

# =========================
# OpenAI, optional
# Isi hanya jika memang dipakai
# =========================
OPENAI_API_KEY=your_openai_key
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# =========================
# Retrieval
# =========================
TOP_K=4
DOC_SIMILARITY_THRESHOLD=0.35
FAQ_SIMILARITY_THRESHOLD=0.78
MAX_CONTEXT_CHARS=6000
MAX_HISTORY_LOG_CHARS=4000

# =========================
# Optional ingest settings
# Pakai hanya jika ingest.py Anda memang membaca ini
# =========================
REFERENCES_DIR=references
CHUNK_SIZE=900
CHUNK_OVERLAP=180
BATCH_SIZE=500
INGEST_RETRY_COUNT=3
INGEST_RETRY_DELAY_SEC=2
MIN_PAGE_TEXT_LEN=40

# =========================
# OCR, optional
# =========================
ENABLE_OCR_FALLBACK=true
OCR_LANG=eng
OCR_DPI=200
OCR_TEXT_MIN_LEN=20
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# =========================
# Optional external verified fallback
# Pakai hanya jika code Anda memang mendukung fitur ini
# =========================
ENABLE_VERIFIED_EXTERNAL_FALLBACK=true
EXTERNAL_SEARCH_TIMEOUT_SEC=12
PUBMED_MAX_RESULTS=3
PUBMED_TOOL_NAME=galih-diabetes-ai-bot
PUBMED_EMAIL=pmelayu313@gmail.com